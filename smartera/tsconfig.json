{
	"extends": "expo/tsconfig.base",
	"compilerOptions": {
		"jsx": "react",
		"strict": true,
		"esModuleInterop": true,
		"plugins": [
			{
				"transform": "expo-router/babel",
				"options": {
					"root": "./src/app"
				}
			},
			{
				"transform": "react-native-reanimated/plugin",
				"relativeSourceLocation": true
			}
		]
	}
}
